    "dialogues": {
      "dlg_01_01": {
        "id": "dlg_01_01",
        "actor": "Lendro",
        "text": "……还开着？",
        "effects": {
          "soundEffectId": null,
          "voiceId": "lendro_01_001"
        }
      },
      "dlg_01_02a": {
        "id": "dlg_01_02a",
        "actor": "酒保",
        "text": "开着。坐吧。"
      },
      "dlg_01_02b": {
        "id": "dlg_01_02b",
        "actor": "",
        "text": "（酒保擦杯子，不说话）"
      },
      "dlg_01_02c": {
        "id": "dlg_01_02c",
        "actor": "酒保",
        "text": "你淋湿了。"
      },
      "dlg_01_03": {
        "id": "dlg_01_03",
        "actor": "Lendro",
        "text": "（拉高脚凳，坐下，动作像在审讯室里找位置）\nLendro：嗯。\n（风衣扣子解开，帽子摘下放在膝上）\nLendro：有什么能喝的。"
      },
      "dlg_01_04a": {
        "id": "dlg_01_04a",
        "actor": "Lendro",
        "text": "随便来点什么。"
      },
      "dlg_01_04b": {
        "id": "dlg_01_04b",
        "actor": "Lendro",
        "text": "随便来点什么。"
      },
      "dlg_01_04c": {
        "id": "dlg_01_04c",
        "actor": "Lendro",
        "text": "（顿了一下，低头看了看自己的肩膀）\nLendro：……习惯了。\n（拉凳子坐下，比前两个选择慢半拍）\nLendro：有什么暖的。"
      },
      "dlg_01_drink_correct": {
        "id": "dlg_01_drink_correct",
        "actor": "Lendro",
        "text": "（端起来，没喝，看了看杯中液体的颜色）\nLendro：……清的。\n（小口抿了一下）\nLendro：还行。\n（微微放松，肩线下降约一指宽）"
      },
      "dlg_01_drink_wrong_whisky": {
        "id": "dlg_01_drink_wrong_whisky",
        "actor": "Lendro",
        "text": "（端起来闻了一下）\nLendro：……太重了。\n（还是喝了一口，放下时杯底磕得比正常响）\nLendro：有清一点的吗。"
      },
      "dlg_01_drink_wrong_beer": {
        "id": "dlg_01_drink_wrong_beer",
        "actor": "Lendro",
        "text": "（看了一眼，没端）\nLendro：……算了。\nLendro：有烈的吗。"
      },
      "dlg_01_drink_wrong_lemon": {
        "id": "dlg_01_drink_wrong_lemon",
        "actor": "Lendro",
        "text": "（端起来喝了一口，表情没变）\nLendro：……你这儿就这些？\n（放下杯子，手指在吧台上无声地敲了两下）"
      },
      "dlg_01_05": {
        "id": "dlg_01_05",
        "actor": "Lendro",
        "text": "（白酒喝到半杯，声音比进门时低了一档）\nLendro：这地方……以前没见过。"
      },
      "dlg_01_06a": {
        "id": "dlg_01_06a",
        "actor": "酒保",
        "text": "新开的。"
      },
      "dlg_01_06b": {
        "id": "dlg_01_06b",
        "actor": "酒保",
        "text": "你以前常去哪？\nLendro：（手指摩挲杯沿）\nLendro：码头那边。第三街拐角有个地下室。\n（停顿）\nLendro：……不去了。\n（视线短暂移向窗外北墙方向，随即收回）"
      },
      "dlg_01_06c": {
        "id": "dlg_01_06c",
        "actor": "",
        "text": "（酒保继续擦杯子）"
      },
      "dlg_01_07": {
        "id": "dlg_01_07",
        "actor": "Lendro",
        "text": "我是个警察。或者说——曾经是。\n（喝一口酒）\nLendro：二十年了。码头区，禁酒令，走私……都是我的辖区。\nLendro：你见过码头凌晨三点的样子吗？"
      },
      "dlg_01_08a": {
        "id": "dlg_01_08a",
        "actor": "酒保",
        "text": "没见过。"
      },
      "dlg_01_08b": {
        "id": "dlg_01_08b",
        "actor": "酒保",
        "text": "三点怎么了？"
      },
      "dlg_01_08c": {
        "id": "dlg_01_08c",
        "actor": "",
        "text": "（安静等他说）"
      },
      "dlg_01_warehouse": {
        "id": "dlg_01_warehouse",
        "actor": "Lendro",
        "text": "（酒已经见底，但没有要续的意思）\nLendro：有个搭档。叫 Eilas。\n（停顿很长，像是在决定要不要说出这个名字）\nLendro：比我年轻五岁。刚从学院出来的时候，是我带的他。\n（握杯的手指关节发白）\nLendro：码头第十七号仓库。线人说那批货当晚到。\nLendro：我们两个人进去的。\n（停顿两秒）\nLendro：……出来的只有我一个。"
      },
      "dlg_01_eilas_a": {
        "id": "dlg_01_eilas_a",
        "actor": "酒保",
        "text": "发生了什么？\nLendro：（看了你一眼，像是在判断你是不是审讯室里的人）\nLendro：……你真想听？\n（不等回答）\nLendro：仓库里不是走私酒。是——\n（突然停住，喉结动了一下）\nLendro：……我不记得了。\n（声音变硬）\nLendro：不。我记得。我只是——\n（停顿）\nLendro：……还没准备好说。\n（防御姿态，肩线重新绷紧）"
      },
      "dlg_01_eilas_b": {
        "id": "dlg_01_eilas_b",
        "actor": "酒保",
        "text": "你不用说了。\nLendro：（明显松了一口气，但嘴角没有上扬）\nLendro：……谢了。\n（把空杯推过来，手指在杯口停了一瞬）\nLendro：下次吧。\n（退回安全距离）"
      },
      "dlg_01_eilas_c": {
        "id": "dlg_01_eilas_c",
        "actor": "",
        "text": "（酒保给他倒酒，不说话）\nLendro：（看着新倒的酒，没立刻端起来）\nLendro：……\nLendro：（低声）你倒酒的时候不问问题。\n（端起来，小口喝）\nLendro：……这样挺好。\n（放松程度最高）"
      },
      "dlg_01_exit": {
        "id": "dlg_01_exit",
        "actor": "Lendro",
        "text": "（不管之前选了什么，最终都会起身）\nLendro：……该走了。\n（风衣扣子扣上，戴上帽子，帽檐压得很低）\nLendro：这地方——\n（停顿）\nLendro：……还开着吧？"
      },
      "dlg_01_farewell_a": {
        "id": "dlg_01_farewell_a",
        "actor": "酒保",
        "text": "一直开着。\nLendro：（点头，推门离开）"
      },
      "dlg_01_farewell_b": {
        "id": "dlg_01_farewell_b",
        "actor": "酒保",
        "text": "你随时来。\nLendro：（顿了一下，没回头，推门离开）"
      },
      "dlg_01_farewell_c": {
        "id": "dlg_01_farewell_c",
        "actor": "",
        "text": "（酒保点头）\nLendro：（推门离开）"
      }
    },
