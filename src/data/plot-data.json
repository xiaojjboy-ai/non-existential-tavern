    "narratives": {
      "narr_01_prologue": {
        "id": "narr_01_prologue",
        "actor": "旁白",
        "text": "外头的雨下得发黑，像是能把骨头都泡酥了。晚上十点一刻，两个避雨的熟客缩在吧台最角落。"
      },
      "narr_01_time": {
        "id": "narr_01_time",
        "actor": "旁白",
        "text": "老麦没答话。他的手指在橡木吧台上轻叩了两下。哒、哒。冲压车间留下的习惯。\n他看了一眼墙上生锈的挂钟。10点17分。"
      },
      "narr_01_leave": {
        "id": "narr_01_leave",
        "actor": "旁白",
        "text": "两个熟客裹紧衣领，骂骂咧咧地钻进黑雨里。门刚关上，风铃还没停。\n酒馆毫无征兆地滑入了另一个地方。雨声没有消失，但突然变了质——像隔着一层深水，变得极其沉闷。\n紧接着，木门被一只粗暴的手猛然推开。"
      },
      "narr_01_lendro_enter": {
        "id": "narr_01_lendro_enter",
        "actor": "旁白",
        "text": "Lendro 带着一身酸湿的寒气闯了进来。他连软呢帽都没摘，雨水混着冷汗顺着帽檐往下砸。他双眼布满血丝，像是一只几天不敢合眼的惊弓之鸟。目光快速剔过酒馆的三个死角，最后重重地砸在吧台前的凳子上。手肘撑住台面，右手食指死死贴着枪套。"
      },
      "narr_01_02_choice": {
        "id": "narr_01_02_choice",
        "actor": "旁白",
        "text": "老麦继续擦着手里那只已经很干净的玻璃杯。（该作何反应？）"
      },
      "narr_01_cultist_enter": {
        "id": "narr_01_cultist_enter",
        "actor": "旁白",
        "text": "空气的温度毫无预兆地降到了冰点。风铃没响，但门缝里像是渗进来一片影子。\n一个穿着暗色长衫、戴着金丝眼镜的“学者”悄无声息地落了座。他的眼睛完全是木然的，像两口枯井。"
      },
      "narr_01_04_action": {
        "id": "narr_01_04_action",
        "actor": "旁白",
        "text": "学者的手极慢地、一寸寸往大衣口袋里摸索。\nLendro 原本搭在吧台上的左手松开了，那只生锈的打火机“啪”地一声掉在木地板上。\n老麦没看他们。"
      },
      "narr_01_cultist_confront": {
        "id": "narr_01_cultist_confront",
        "actor": "旁白",
        "text": "就在学者视线被老麦动作牵扯的一瞬——\nLendro 弯腰去捡打火机，但起身的刹那，他的身形已经暴起！\n\n一只脚如铁钉般死死踩住了学者的皮鞋，柯尔特转轮手枪的冷硬枪口，已经稳稳顶在了学者的下颌骨上。",
        "inlineCommands": [
          {
            "type": "SHAKE"
          }
        ]
      },
      "narr_01_cultist_vanish": {
        "id": "narr_01_cultist_vanish",
        "actor": "旁白",
        "text": "学者的身影在枪口下瞬间扭曲拉伸，伴随着刺眼的白光闪烁。\n不到半秒，凳子上空无一人。只留下一件湿透的长衫大衣软塌塌地搭在椅背上，地上有一滩正散发着浓烈鱼腐恶臭的暗红色黏土。\nLendro 剧烈喘息着，枪口还举在半空，眼底的恐惧与迷茫终于压制不住。",
        "inlineCommands": [
          {
            "type": "GLITCH"
          },
          {
            "type": "FLASH"
          }
        ]
      }
    },
